rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    function tenantMemberDoc(tenantId) {
      return firestore.get(/databases/(default)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    // Check if user belongs to this tenant
    function isTenantMember(tenantId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    // Check if user is admin (owner or hr-admin) for this tenant
    function isTenantAdmin(tenantId) {
      return isTenantMember(tenantId) &&
        tenantMemberDoc(tenantId).data.role in ['owner', 'hr-admin'];
    }

    function isTenantManagerOrAdmin(tenantId) {
      return isTenantMember(tenantId) &&
        tenantMemberDoc(tenantId).data.role in ['owner', 'hr-admin', 'manager'];
    }

    function getTenantModules(tenantId) {
      return isTenantMember(tenantId) ? tenantMemberDoc(tenantId).data.modules : [];
    }

    function hasTenantModule(tenantId, module) {
      return isTenantMember(tenantId) && (
        tenantMemberDoc(tenantId).data.role in ['owner', 'hr-admin'] ||
        (getTenantModules(tenantId) is list && getTenantModules(tenantId).hasAny([module]))
      );
    }

    function canAccessHiringRecords(tenantId) {
      return hasTenantModule(tenantId, 'hiring');
    }

    function canAccessStaffRecords(tenantId) {
      return isTenantManagerOrAdmin(tenantId) || hasTenantModule(tenantId, 'staff');
    }

    // File size limit: 10 MB
    function isUnderSizeLimit() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    // Allowed document MIME types (images, PDFs, common office docs)
    function isAllowedDocType() {
      return request.resource.contentType.matches('image/.*') ||
        request.resource.contentType == 'application/pdf' ||
        request.resource.contentType == 'application/msword' ||
        request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document';
    }

    function isAllowedImageType() {
      return request.resource.contentType.matches('image/.*');
    }

    function isOpenJob(tenantId, jobId) {
      return firestore.exists(/databases/(default)/documents/jobs/$(jobId)) &&
        firestore.get(/databases/(default)/documents/jobs/$(jobId)).data.tenantId == tenantId &&
        firestore.get(/databases/(default)/documents/jobs/$(jobId)).data.status == 'open';
    }

    // ============================================
    // TENANT-SCOPED RULES
    // ============================================

    // Employee documents (work contracts, visas, IDs, medical certs)
    match /tenants/{tenantId}/employees/{employeeId}/documents/{document} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantAdmin(tenantId) && isUnderSizeLimit() && isAllowedDocType();
    }

    // Onboarding documents captured by HR during onboarding.
    match /tenants/{tenantId}/onboarding/{caseId}/documents/{document} {
      allow read: if canAccessHiringRecords(tenantId) || canAccessStaffRecords(tenantId);
      allow write: if (canAccessHiringRecords(tenantId) || canAccessStaffRecords(tenantId)) &&
        isUnderSizeLimit() &&
        isAllowedDocType();
    }

    // Public candidate application uploads.
    // Files are stored privately; only internal hiring/staff users can read them later.
    match /public/jobApplications/{tenantId}/{jobId}/{allPaths=**} {
      allow read: if canAccessHiringRecords(tenantId) || canAccessStaffRecords(tenantId);
      allow write: if isOpenJob(tenantId, jobId) &&
        isUnderSizeLimit() &&
        isAllowedDocType();
    }

    // Expense receipts
    match /tenants/{tenantId}/expenses/{expenseId}/receipts/{document} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantMember(tenantId) && isUnderSizeLimit();
    }

    // Payslip PDFs
    match /tenants/{tenantId}/payslips/{payrollRunId}/{document} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantAdmin(tenantId) && isUnderSizeLimit();
    }

    // Tenant branding assets (company logos)
    match /tenants/{tenantId}/branding/{allPaths=**} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantAdmin(tenantId) && isUnderSizeLimit() && isAllowedImageType();
    }

    // Attendance photos (supervisor crew clock-in)
    match /attendance_photos/{tenantId}/{date}/{fileName} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantMember(tenantId)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/jpeg');
    }

    // ============================================
    // LEGACY PATHS (pre-tenant-isolation, read-only for migration)
    // Remove once all existing files are migrated
    // ============================================
    match /employees/{employeeId}/documents/{document} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /expenses/{expenseId}/{document} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
