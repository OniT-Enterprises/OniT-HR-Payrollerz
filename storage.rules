rules_version = '2';
// Cross-service note: these rules call firestore.get()/exists(), which only
// works if the STORAGE service agent (service-<project#>@gcp-sa-firebasestorage
// .iam.gserviceaccount.com) holds roles/firebaserules.firestoreServiceAgent.
// Granted 2026-07-17 — without it every membership-gated upload 403s, and
// scripts/deploy-rules.mjs (Admin SDK) never provisions it the way the CLI does.
service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Platform superadmin (custom claim, falling back to the users doc flag).
    // Mirrors firestore.rules isSuperAdmin() so impersonation works for
    // tenant files too — superadmins are not tenant members.
    function isPlatformSuperAdmin() {
      return isAuthenticated() && (
        (
          request.auth.token.keys().hasAny(['superadmin']) &&
          request.auth.token.superadmin == true
        ) ||
        (
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true
        )
      );
    }

    function tenantMemberDoc(tenantId) {
      return firestore.get(/databases/(default)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    // Actual membership doc check — superadmin bypass is added in the
    // isTenant* wrappers below, kept second so members never pay its reads.
    function isRealTenantMember(tenantId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    // Check if user belongs to this tenant
    function isTenantMember(tenantId) {
      return isRealTenantMember(tenantId) || isPlatformSuperAdmin();
    }

    // Check if user is admin (owner or hr-admin) for this tenant
    function isTenantAdmin(tenantId) {
      return (isRealTenantMember(tenantId) &&
        tenantMemberDoc(tenantId).data.role in ['owner', 'hr-admin']) ||
        isPlatformSuperAdmin();
    }

    // Finance-power roles: 'accountant' writes money/accounting records like an
    // admin (mirrors firestore.rules isTenantFinanceAdmin) so the finance set
    // that can send invoices can also freeze the as-sent invoice PDF.
    function isTenantFinanceAdmin(tenantId) {
      return (isRealTenantMember(tenantId) &&
        tenantMemberDoc(tenantId).data.role in ['owner', 'hr-admin', 'accountant']) ||
        isPlatformSuperAdmin();
    }

    function isTenantManagerOrAdmin(tenantId) {
      return (isRealTenantMember(tenantId) &&
        tenantMemberDoc(tenantId).data.role in ['owner', 'hr-admin', 'manager']) ||
        isPlatformSuperAdmin();
    }

    function getTenantModules(tenantId) {
      return isRealTenantMember(tenantId) ? tenantMemberDoc(tenantId).data.modules : [];
    }

    function hasTenantModule(tenantId, module) {
      return (isRealTenantMember(tenantId) && (
        tenantMemberDoc(tenantId).data.role in ['owner', 'hr-admin'] ||
        (getTenantModules(tenantId) is list && getTenantModules(tenantId).hasAny([module]))
      )) || isPlatformSuperAdmin();
    }

    function canAccessHiringRecords(tenantId) {
      return hasTenantModule(tenantId, 'hiring');
    }

    function canAccessStaffRecords(tenantId) {
      return isTenantManagerOrAdmin(tenantId) || hasTenantModule(tenantId, 'staff');
    }

    // Mirrors firestore.rules canAccessPayrollRecords — gates payslip PDFs to
    // the payroll set (owner/hr-admin auto, plus anyone with the payroll
    // module), NOT every tenant member.
    function canAccessPayrollRecords(tenantId) {
      return hasTenantModule(tenantId, 'payroll');
    }

    // The employeeId linked to the calling member (null if none / not a member).
    // isSelfEmployee equivalent for Storage: lets a worker reach their own
    // employee documents and payslips without opening them to colleagues.
    function storageEmployeeId(tenantId) {
      return isRealTenantMember(tenantId)
        ? tenantMemberDoc(tenantId).data.get('employeeId', null)
        : null;
    }

    // Payslip objects are named "<employeeId>_<timestamp>.pdf" (see
    // emailService.uploadPayslipPdf), so a worker's own payslips are the files
    // whose name is prefixed with their employeeId.
    function isOwnPayslipFile(tenantId, fileName) {
      return storageEmployeeId(tenantId) != null &&
        fileName.matches('^' + storageEmployeeId(tenantId) + '_.*');
    }

    // File size limit: 10 MB
    function isUnderSizeLimit() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    // Allowed document MIME types (images, PDFs, common office docs)
    function isAllowedDocType() {
      return request.resource.contentType.matches('image/.*') ||
        request.resource.contentType == 'application/pdf' ||
        request.resource.contentType == 'application/msword' ||
        request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document';
    }

    function isAllowedImageType() {
      return request.resource.contentType.matches('image/.*');
    }

    // Resume/CV documents only — no images. Used on the PUBLIC (unauthenticated)
    // job-application path, so it is deliberately stricter than isAllowedDocType.
    function isResumeDocType() {
      return request.resource.contentType == 'application/pdf' ||
        request.resource.contentType == 'application/msword' ||
        request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document';
    }

    // Tighter cap for anonymous uploads (cost/spam control): 4 MB is ample for
    // a CV and far below the 10 MB authenticated limit.
    function isUnderPublicUploadLimit() {
      return request.resource.size < 4 * 1024 * 1024;
    }

    function isOpenJob(tenantId, jobId) {
      return firestore.exists(/databases/(default)/documents/jobs/$(jobId)) &&
        firestore.get(/databases/(default)/documents/jobs/$(jobId)).data.tenantId == tenantId &&
        firestore.get(/databases/(default)/documents/jobs/$(jobId)).data.status == 'open';
    }

    // ============================================
    // TENANT-SCOPED RULES
    // ============================================

    // Employee documents (work contracts, visas, IDs, medical certs).
    // Firestore gates the matching employee records to staff/hiring access or
    // the employee themselves — Storage must match, or IDs and medical certs
    // leak to any signed-in colleague.
    match /tenants/{tenantId}/employees/{employeeId}/documents/{document} {
      allow read: if canAccessStaffRecords(tenantId) ||
        canAccessHiringRecords(tenantId) ||
        storageEmployeeId(tenantId) == employeeId;
      allow write: if isTenantAdmin(tenantId) && isUnderSizeLimit() && isAllowedDocType();
    }

    // Onboarding documents captured by HR during onboarding.
    match /tenants/{tenantId}/onboarding/{caseId}/documents/{document} {
      allow read: if canAccessHiringRecords(tenantId) || canAccessStaffRecords(tenantId);
      allow write: if (canAccessHiringRecords(tenantId) || canAccessStaffRecords(tenantId)) &&
        isUnderSizeLimit() &&
        isAllowedDocType();
    }

    // Public candidate application uploads.
    // Files are stored privately; only internal hiring/staff users can read them later.
    match /public/jobApplications/{tenantId}/{jobId}/{applicationId}/{fileName} {
      allow read: if canAccessHiringRecords(tenantId) || canAccessStaffRecords(tenantId);
      // Unauthenticated write: keep it tight — 4 MB cap, CV document types only
      // (no images, unlike the authenticated doc paths), single fixed filename.
      allow write: if isOpenJob(tenantId, jobId) &&
        isUnderPublicUploadLimit() &&
        isResumeDocType() &&
        fileName.matches('resume\\.(pdf|doc|docx)');
    }

    // Expense receipts
    match /tenants/{tenantId}/expenses/{expenseId}/receipts/{document} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantMember(tenantId) && isUnderSizeLimit();
    }

    // Bill attachments (vendor invoices, receipts)
    match /tenants/{tenantId}/bills/{billId}/attachments/{document} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantMember(tenantId) && isUnderSizeLimit() && isAllowedDocType();
    }

    // Evidence for actual ATTL supplier-withholding payments.
    match /tenants/{tenantId}/supplier-withholding/{remittanceId}/{document} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantAdmin(tenantId) && isUnderSizeLimit() && isAllowedDocType();
    }

    match /tenants/{tenantId}/tax-clearance/{requestId}/{document} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantAdmin(tenantId) && isUnderSizeLimit() &&
        request.resource.contentType == 'application/pdf';
    }

    match /tenants/{tenantId}/cash-advances/{advanceId}/{document} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantAdmin(tenantId) && isUnderSizeLimit() && isAllowedDocType();
    }

    // As-sent customer invoice PDFs, frozen at send time. Customers reach
    // them through the tokenized download URL stored on invoice_links docs.
    // Writable by the finance set (owner/hr-admin/accountant) — accountants can
    // send invoices, so they must be able to freeze the as-sent PDF too.
    // NOTE: NOT storage-level write-once on purpose. invoiceService.
    // rotateFrozenPdfToken re-uploads the SAME bytes to this deterministic path
    // to mint a fresh download token (a "revoke the old shared link" feature),
    // which is an `update`. Rules can't tell an identical-bytes rotation from a
    // malicious overwrite, so a deny-update would break that shipped flow. The
    // as-sent content stays frozen at the app layer (the PDF is re-uploaded, never
    // re-rendered — see docs/INVOICING.md).
    match /tenants/{tenantId}/invoices/{invoiceId}/{document} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantFinanceAdmin(tenantId) && isUnderSizeLimit() &&
        request.resource.contentType == 'application/pdf';
    }

    // Payslip PDFs — salary data. Readable by the payroll set or by the
    // employee whose payslip it is (matched on the "<employeeId>_" filename
    // prefix), NOT every tenant member (mirrors firestore payrollRecords).
    match /tenants/{tenantId}/payslips/{payrollRunId}/{document} {
      allow read: if canAccessPayrollRecords(tenantId) ||
        isOwnPayslipFile(tenantId, document);
      allow write: if isTenantAdmin(tenantId) && isUnderSizeLimit();
    }

    // Tenant branding assets (company logos)
    match /tenants/{tenantId}/branding/{allPaths=**} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantAdmin(tenantId) && isUnderSizeLimit() && isAllowedImageType();
    }

    // ============================================
    // PLATFORM-WIDE FILES
    // ============================================

    // Contract template files (uploaded by superadmins, readable by all tenants)
    match /platform/contractTemplates/{templateId}/{fileName} {
      allow read: if isAuthenticated();
      allow create, update: if isPlatformSuperAdmin() && isUnderSizeLimit() && isAllowedDocType();
      allow delete: if isPlatformSuperAdmin();
    }

    // Attendance photos (supervisor crew clock-in)
    match /attendance_photos/{tenantId}/{date}/{fileName} {
      allow read: if isTenantMember(tenantId);
      allow write: if isTenantMember(tenantId)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/jpeg');
    }

    // Legacy pre-tenant-isolation paths (/employees/**, /expenses/**) were
    // removed 2026-07-18 after verifying both prefixes are empty in the
    // production bucket — they allowed cross-tenant reads to any signed-in
    // user. The catch-all below now denies them (pinned by
    // tests/rules/storage-rules.test.ts).

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
