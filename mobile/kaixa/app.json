{
  "expo": {
    "name": "Kaixa",
    "slug": "kaixa",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kaixa",
    "backgroundColor": "#0C0A09",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0A09"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "tl.onit.kaixa",
      "backgroundColor": "#0C0A09"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C0A09"
      },
      "package": "tl.onit.kaixa"
    },
    "plugins": [
      "expo-router",
      "expo-system-ui",
      [
        "expo-navigation-bar",
        {
          "barStyle": "light"
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "autolinkingModuleResolution": true
    }
  }
}
