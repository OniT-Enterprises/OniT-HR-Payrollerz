rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is a superadmin via the user document
    function isSuperAdmin() {
      return isAuthenticated() && (
        (
          request.auth.token.keys().hasAny(['superadmin']) &&
          request.auth.token.superadmin == true
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true
        )
      );
    }

    // Check if user is a member of the specified tenant
    function isTenantMember(tenantId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    // Get the user's role in the specified tenant
    function getTenantRole(tenantId) {
      return isTenantMember(tenantId)
        ? get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.role
        : null;
    }

    // Check if user is owner or hr-admin in the tenant
    function isTenantAdmin(tenantId) {
      return isAuthenticated() &&
        isTenantMember(tenantId) &&
        getTenantRole(tenantId) in ['owner', 'hr-admin'];
    }

    // Check if user is the tenant owner
    function isTenantOwner(tenantId) {
      return isAuthenticated() &&
        isTenantMember(tenantId) &&
        getTenantRole(tenantId) == 'owner';
    }

    // Finance-power roles: 'accountant' writes money/accounting/payroll
    // records like an admin, but has no member/employee/tenant administration.
    function isTenantFinanceAdmin(tenantId) {
      return isAuthenticated() &&
        isTenantMember(tenantId) &&
        getTenantRole(tenantId) in ['owner', 'hr-admin', 'accountant'];
    }

    function getTenantMember(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }

    function getTenantModules(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid))
        ? getTenantMember(tenantId).data.modules
        : [];
    }

    function getTenantEmployeeId(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid))
        ? getTenantMember(tenantId).data.employeeId
        : null;
    }

    function isTenantManagerOrAdmin(tenantId) {
      return isAuthenticated() &&
        isTenantMember(tenantId) &&
        getTenantRole(tenantId) in ['owner', 'hr-admin', 'manager'];
    }

    // Self-service tenant creation. The billing/paywall fields are blocked
    // here for the same reason the tenant UPDATE rule blocks them: only the
    // Stripe webhook / superadmins may set them. Without this guard a user
    // could CREATE their tenant pre-subscribed (manualSubscription: true +
    // far-future subscriptionPaidUntil) and bypass the payroll paywall.
    function canCreateOwnTenant(tenantId) {
      return isAuthenticated() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.id == tenantId &&
        !request.resource.data.keys().hasAny([
          'stripeCustomerId', 'stripeSubscriptionId', 'subscriptionPaidUntil',
          'manualSubscription', 'monthlySubscriptionAmount',
          'subscriptionBillingAmount', 'subscriptionBillingInterval',
          'subscriptionBillingMonths', 'subscriptionBilledSeats',
          'subscriptionAnnualMonthsCharged',
          'subscriptionAnnualPaidSeats', 'subscriptionTermStart', 'pendingCheckout',
          'lastStripeSubscriptionEventAt'
        ]);
    }

    function canCreateInitialOwnerMembership(tenantId, memberId) {
      return isAuthenticated() &&
        memberId == request.auth.uid &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.createdBy == request.auth.uid &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.role == 'owner';
    }

    function hasTenantModule(tenantId, module) {
      return isAuthenticated() &&
        isTenantMember(tenantId) && (
          getTenantRole(tenantId) in ['owner', 'hr-admin'] ||
          (getTenantModules(tenantId) is list &&
           getTenantModules(tenantId).hasAny([module]))
        );
    }

    function canAccessStaffRecords(tenantId) {
      return isTenantManagerOrAdmin(tenantId) || hasTenantModule(tenantId, 'staff');
    }

    function canAccessHiringRecords(tenantId) {
      return hasTenantModule(tenantId, 'hiring');
    }

    function canAccessTimeLeaveRecords(tenantId) {
      return isTenantFinanceAdmin(tenantId) ||
        (isTenantMember(tenantId) && getTenantRole(tenantId) == 'manager');
    }

    function canManageTimeLeaveRecords(tenantId) {
      return isTenantAdmin(tenantId) ||
        (isTenantMember(tenantId) && getTenantRole(tenantId) == 'manager');
    }

    function isManagerForDepartment(tenantId, departmentId) {
      return departmentId != null &&
        isTenantMember(tenantId) &&
        getTenantRole(tenantId) == 'manager' &&
        getTenantMember(tenantId).data.get('departmentId', null) == departmentId;
    }

    function employeeInDepartment(tenantId, employeeId, departmentId) {
      return employeeId != null && departmentId != null &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)/employees/$(employeeId)) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/employees/$(employeeId))
          .data.jobDetails.departmentId == departmentId;
    }

    function canAccessPayrollRecords(tenantId) {
      return hasTenantModule(tenantId, 'payroll');
    }

    function canAccessMoneyRecords(tenantId) {
      return hasTenantModule(tenantId, 'money') || hasTenantModule(tenantId, 'accounting');
    }

    function canAccessAccountingRecords(tenantId) {
      return hasTenantModule(tenantId, 'accounting');
    }

    // Firestore numbers are doubles. Monetary values are stored to cents by
    // the client, but transaction arithmetic in rules can retain a tiny binary
    // fraction; compare with a sub-cent tolerance rather than exact equality.
    function moneyClose(left, right) {
      return left >= right - 0.00001 && left <= right + 0.00001;
    }

    function isSelfEmployee(tenantId, employeeId) {
      return isAuthenticated() &&
        isTenantMember(tenantId) &&
        getTenantEmployeeId(tenantId) == employeeId;
    }

    // Solo-operator mode: tenant settings can opt in to letting the creator of a
    // payroll run approve it themselves (default is the two-person rule).
    // exists() guard first — a failed get() would deny the whole update.
    function allowsSelfApproval(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId)/settings/config) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/settings/config)
          .data.get('payrollConfig', {}).get('allowSelfApproval', false) == true;
    }

    // Paywall backstop: moving a payroll run to 'approved' (finalizing) requires
    // an active subscription — mirrors isTenantSubscribed() in
    // client/lib/packagePricing.ts (keep in sync). Two paths:
    //  - Stripe: webhook-managed stripeSubscriptionId; subscriptionPaidUntil
    //    (when present) must not be in the past.
    //  - Manual (bank transfer / cash, recorded by superadmins): requires
    //    manualSubscription == true AND an unexpired subscriptionPaidUntil.
    // exists() guard first — a failed get() would deny the whole update.
    function tenantHasActiveSubscription(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId)) && (
        (
          get(/databases/$(database)/documents/tenants/$(tenantId))
            .data.get('stripeSubscriptionId', '') != '' &&
          (get(/databases/$(database)/documents/tenants/$(tenantId))
             .data.get('subscriptionPaidUntil', null) == null ||
           get(/databases/$(database)/documents/tenants/$(tenantId))
             .data.get('subscriptionPaidUntil', null) > request.time)
        ) || (
          get(/databases/$(database)/documents/tenants/$(tenantId))
            .data.get('manualSubscription', false) == true &&
          get(/databases/$(database)/documents/tenants/$(tenantId))
            .data.get('subscriptionPaidUntil', null) != null &&
          get(/databases/$(database)/documents/tenants/$(tenantId))
            .data.get('subscriptionPaidUntil', null) > request.time
        )
      );
    }

    // ============================================
    // USER PROFILES (Global, not tenant-scoped)
    // ============================================
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;

      // Superadmins can read any user profile
      allow read: if isSuperAdmin();

      // Users can update their own profile (except isSuperAdmin field)
      allow update: if isAuthenticated() &&
        request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isSuperAdmin']);

      // Superadmins can update any user (including isSuperAdmin)
      allow update: if isSuperAdmin();

      // Users can create their own profile (but not as superadmin)
      allow create: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.data.isSuperAdmin == false;

      // Superadmins can create any profile
      allow create: if isSuperAdmin();

      // Only superadmins can delete user profiles
      allow delete: if isSuperAdmin();
    }

    // User device tokens for push notifications (Ekipa)
    match /users/{userId}/devices/{tokenId} {
      // Users can manage their own device tokens
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      // Superadmins can read all (for debugging)
      allow read: if isSuperAdmin();
    }

    // Bootstrap document - locked. Superadmin setup is handled via Firebase Admin SDK.
    match /_bootstrap/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================
    // ADMIN AUDIT LOG (superadmin actions)
    // ============================================
    match /adminAuditLog/{entryId} {
      // Only superadmins can read audit logs
      allow read: if isSuperAdmin();

      // Cloud Functions write audit entries with a trusted actor identity.
      allow create: if false;

      // Audit logs are immutable
      allow update, delete: if false;
    }

    // ============================================
    // PLATFORM CONFIGURATION (superadmin only)
    // ============================================
    match /platform/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /platform/packagesConfig {
      // Published pricing is not sensitive. Guests may read it so the public
      // landing page and authenticated checkout always show the same values.
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ============================================
    // SUPERADMIN APPROVAL REQUESTS
    // ============================================
    match /superAdminRequests/{requestId} {
      allow read, write: if isSuperAdmin();
    }

    // ============================================
    // AUDIT LOGS (tenant-level compliance trail)
    // ============================================
    match /audit_logs/{entryId} {
      // Superadmins can read all audit logs
      // SECURITY: Restricted to admins only — audit logs contain sensitive info
      // (salary changes, disciplinary actions, etc.)
      allow read: if isSuperAdmin() ||
        (isAuthenticated() &&
         resource.data.tenantId != null &&
         isTenantAdmin(resource.data.tenantId));

      // Legacy collection: no direct client audit writes.
      allow create: if false;

      // Audit logs are immutable - no updates or deletes
      allow update, delete: if false;
    }

    // ============================================
    // TENANTS ROOT COLLECTION
    // ============================================
    match /tenants/{tenantId} {
      // Superadmins can do anything with tenants
      allow read, write: if isSuperAdmin();

      // Tenant members can read their tenant config
      allow read: if isTenantMember(tenantId);

      // Only tenant owners can update config — but never the billing/paywall
      // fields (only the Stripe webhook / superadmins set those; a tenant
      // writing stripeSubscriptionId or manualSubscription themselves would
      // self-activate the payroll paywall).
      allow update: if isTenantOwner(tenantId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'status', 'plan', 'limits', 'stripeCustomerId',
          'stripeSubscriptionId', 'subscriptionPaidUntil',
          'manualSubscription', 'monthlySubscriptionAmount',
          'subscriptionBillingAmount', 'subscriptionBillingInterval',
          'subscriptionBillingMonths', 'subscriptionBilledSeats',
          'subscriptionAnnualMonthsCharged',
          'subscriptionAnnualPaidSeats', 'subscriptionTermStart', 'pendingCheckout',
          // Webhook ordering watermark (functions/src/billing.ts). If an owner
          // could push it into the future, Stripe cancellation events would be
          // dropped as "stale" and the paywall would stay unlocked unpaid.
          'lastStripeSubscriptionEventAt'
        ]);

      // Creating new tenants requires authentication and self-ownership
      allow create: if canCreateOwnTenant(tenantId);

      // ============================================
      // TENANT MEMBERS SUBCOLLECTION
      // ============================================
      match /members/{memberId} {
        // Superadmins can do anything
        allow read, write: if isSuperAdmin();

        // Tenant members can read member list
        allow read: if isTenantMember(tenantId);

        // Allow self-service signup to create the initial owner membership
        allow create: if (isTenantAdmin(tenantId) && memberId != request.auth.uid) ||
          canCreateInitialOwnerMembership(tenantId, memberId);

        // Only tenant admins can manage other members
        allow update: if isTenantAdmin(tenantId) && memberId != request.auth.uid;
        allow delete: if isTenantAdmin(tenantId) && memberId != request.auth.uid;

        // Users can update their own member record (allowlist ONLY).
        // employeeId is the identity isSelfEmployee() resolves from — letting a
        // member change it (or uid/email/departmentId/partner links) would let
        // them impersonate a colleague and read their payslips/PII. Fail closed:
        // anything not listed here is admin-managed.
        allow update: if isAuthenticated() &&
          request.auth.uid == memberId &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['displayName', 'lastActiveAt']);
      }

      // ============================================
      // TENANT SETTINGS SUBCOLLECTION
      // ============================================
      match /settings/{docId} {
        allow read: if isSuperAdmin() || (
          (docId == 'integrations' && isTenantAdmin(tenantId)) ||
          (docId != 'integrations' && isTenantMember(tenantId))
        );
        // Accountants manage payroll/tax configuration but not integrations
        // (external credentials stay owner/hr-admin only).
        // payrollConfig.allowSelfApproval waives the two-person payroll
        // approval rule, so CHANGING it is owner-only — the finance roles it
        // constrains (hr-admin/accountant) must not be able to flip it and
        // then self-approve their own runs. Unrelated config saves that carry
        // the flag through unchanged still pass.
        allow create: if isSuperAdmin() || (
          (isTenantAdmin(tenantId) ||
            (docId != 'integrations' && isTenantFinanceAdmin(tenantId))) &&
          (isTenantOwner(tenantId) ||
            request.resource.data.get('payrollConfig', {})
              .get('allowSelfApproval', false) == false)
        );
        allow update: if isSuperAdmin() || (
          (isTenantAdmin(tenantId) ||
            (docId != 'integrations' && isTenantFinanceAdmin(tenantId))) &&
          (isTenantOwner(tenantId) ||
            request.resource.data.get('payrollConfig', {})
              .get('allowSelfApproval', false) ==
            resource.data.get('payrollConfig', {})
              .get('allowSelfApproval', false))
        );
        allow delete: if isSuperAdmin() || isTenantAdmin(tenantId) ||
          (docId != 'integrations' && isTenantFinanceAdmin(tenantId));
      }

      // ============================================
      // EMPLOYEES SUBCOLLECTION
      // ============================================
      match /employees/{employeeId} {
        allow read: if isSuperAdmin() ||
          canAccessHiringRecords(tenantId) ||
          canAccessStaffRecords(tenantId) ||
          isSelfEmployee(tenantId, employeeId);

        allow create, delete: if isSuperAdmin() || isTenantAdmin(tenantId);

        allow update: if isSuperAdmin() || isTenantAdmin(tenantId) || (
            canAccessHiringRecords(tenantId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'jobDetails',
              'compliance',
              'updatedAt',
            ]) &&
            request.resource.data.keys().hasAny(['jobDetails']) &&
            request.resource.data.jobDetails is map &&
            (
              (
                resource.data.keys().hasAny(['jobDetails']) &&
                resource.data.jobDetails is map &&
                request.resource.data.jobDetails.diff(resource.data.jobDetails).affectedKeys()
                  .hasOnly(['manager'])
              ) ||
              (
                !resource.data.keys().hasAny(['jobDetails']) &&
                request.resource.data.jobDetails.keys().hasOnly(['manager'])
              )
            )
          ) || (
            isSelfEmployee(tenantId, employeeId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'personalInfo',
              'phone',
              'address',
              'emergencyContactName',
              'emergencyContactPhone',
              'updatedAt',
            ]) &&
            (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['personalInfo']) ||
              (
                request.resource.data.keys().hasAny(['personalInfo']) &&
                request.resource.data.personalInfo is map &&
                (
                  (
                    resource.data.keys().hasAny(['personalInfo']) &&
                    resource.data.personalInfo is map &&
                    request.resource.data.personalInfo.diff(resource.data.personalInfo).affectedKeys()
                      .hasOnly([
                        'phone',
                        'address',
                        'emergencyContactName',
                        'emergencyContactPhone',
                      ])
                  ) ||
                  (
                    !resource.data.keys().hasAny(['personalInfo']) &&
                    request.resource.data.personalInfo.keys().hasOnly([
                      'phone',
                      'address',
                      'emergencyContactName',
                      'emergencyContactPhone',
                    ])
                  )
                )
              )
            )
          );
      }

      // ============================================
      // DEPARTMENTS SUBCOLLECTION
      // ============================================
      match /departments/{departmentId} {
        allow read: if isSuperAdmin() || isTenantMember(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // POSITIONS SUBCOLLECTION
      // ============================================
      match /positions/{positionId} {
        allow read: if isSuperAdmin() || canAccessHiringRecords(tenantId) || canAccessStaffRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // JOBS SUBCOLLECTION
      // ============================================
      match /jobs/{jobId} {
        allow read: if isSuperAdmin() || canAccessHiringRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // CANDIDATES SUBCOLLECTION
      // ============================================
      match /candidates/{candidateId} {
        allow read: if isSuperAdmin() || canAccessHiringRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // INTERVIEWS SUBCOLLECTION
      // ============================================
      match /interviews/{interviewId} {
        allow read: if isSuperAdmin() || canAccessHiringRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // CONTRACTS SUBCOLLECTION
      // ============================================
      match /contracts/{contractId} {
        allow read: if isSuperAdmin() || canAccessHiringRecords(tenantId) || canAccessStaffRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // LEAVE REQUESTS SUBCOLLECTION
      // ============================================
      match /leaveRequests/{requestId} {
        // Retired schema. Canonical requests live in top-level /leave_requests.
        allow read, write: if isSuperAdmin();
      }

      // ============================================
      // TIMESHEETS SUBCOLLECTION
      // ============================================
      match /timesheets/{timesheetId} {
        // Computed by Cloud Functions. Clients can read only their own row or
        // finance/HR rows; direct client writes are never authoritative.
        allow read: if isSuperAdmin() || isTenantFinanceAdmin(tenantId) || (
          resource.data.employeeId != null &&
          isSelfEmployee(tenantId, resource.data.employeeId)
        );
        allow write: if isSuperAdmin();
      }

      // ============================================
      // PAYROLL RUNS SUBCOLLECTION
      // ============================================
      match /payruns/{payrunId} {
        allow read: if isSuperAdmin() || canAccessPayrollRecords(tenantId);
        allow create: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        // Prevent createdBy tampering + two-person approval rule
        // (unless tenant opted in to solo self-approval)
        allow update: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) &&
          request.resource.data.createdBy == resource.data.createdBy &&
          (request.resource.data.status != 'approved' ||
           request.resource.data.approvedBy != resource.data.createdBy ||
           allowsSelfApproval(tenantId)) &&
          // Paywall: the transition INTO 'approved' requires an active
          // subscription (already-approved runs stay editable if it lapses)
          (request.resource.data.status != 'approved' ||
           resource.data.status == 'approved' ||
           tenantHasActiveSubscription(tenantId))
        );
        allow delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);

        // Payslips under payrun
        match /payslips/{payslipId} {
          allow read: if isSuperAdmin() ||
            canAccessPayrollRecords(tenantId) ||
            isSelfEmployee(tenantId, payslipId) ||
            (resource.data.employeeId != null &&
             isSelfEmployee(tenantId, resource.data.employeeId));
          allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        }
      }

      // ============================================
      // GOALS SUBCOLLECTION
      // ============================================
      match /goals/{goalId} {
        allow read, create, update: if isSuperAdmin() || isTenantAdmin(tenantId);
        allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // REVIEWS SUBCOLLECTION
      // ============================================
      match /reviews/{reviewId} {
        allow read: if isSuperAdmin() ||
          isTenantAdmin(tenantId) ||
          (resource.data.employeeId != null &&
           resource.data.status != 'draft' &&
           isSelfEmployee(tenantId, resource.data.employeeId));
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // TRAININGS SUBCOLLECTION
      // ============================================
      match /trainings/{trainingId} {
        allow read: if isSuperAdmin() ||
          isTenantAdmin(tenantId) ||
          (resource.data.employeeId != null &&
           isSelfEmployee(tenantId, resource.data.employeeId));
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // DISCIPLINE SUBCOLLECTION
      // ============================================
      match /discipline/{disciplineId} {
        allow read: if isSuperAdmin() || isTenantAdmin(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // AUDIT LOGS SUBCOLLECTION (Tenant-scoped)
      // ============================================
      match /auditLogs/{logId} {
        allow read: if isSuperAdmin() || isTenantAdmin(tenantId);
        // Cloud Functions write audit entries with a trusted actor identity.
        // Clients may also write them — the accounting service records the
        // journal-post audit inside the posting transaction (atomicity) — but
        // only for finance admins and only self-attributed: a client can never
        // write an entry naming anyone but itself.
        allow create: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.tenantId == tenantId
        );
        // Audit logs are immutable.
        allow update, delete: if false;
      }

      // ============================================
      // ARCHIVES SUBCOLLECTION (Tenant-scoped)
      // ============================================
      match /archives/{archiveId} {
        allow read: if isSuperAdmin() || isTenantAdmin(tenantId);
        allow create, update: if isSuperAdmin() || isTenantAdmin(tenantId);
        // Permanent deletion reserved for superadmins
        allow delete: if isSuperAdmin();
      }

      // ============================================
      // QUICKBOOKS EXPORT LOGS SUBCOLLECTION (Tenant-scoped)
      // ============================================
      match /qbExportLogs/{logId} {
        allow read: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        allow create: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        // Export logs are immutable
        allow update, delete: if false;
      }

      // ============================================
      // ACCOUNTING MODULE SUBCOLLECTIONS
      // ============================================
      match /accounts/{accountId} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /journalEntries/{entryId} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        // Balance validation (totalDebit == totalCredit) is enforced client-side
        // with 0.01 tolerance. Rules use strict == which fails on float rounding,
        // so we only enforce role-based access here.
        allow create: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        // Draft entries can be edited and posted.
        // Posted entries can be voided (immutable amounts/lines).
        allow update: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) && (
            // Draft -> Draft or Draft -> Posted
            (
              resource.data.status == 'draft' &&
              request.resource.data.status in ['draft', 'posted']
            )
            ||
            // Posted -> Void (only void metadata may change)
            (
              resource.data.status == 'posted' &&
              request.resource.data.status == 'void' &&
              request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'voidedAt', 'voidedBy', 'voidReason'])
            )
          )
        );
        allow delete: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) &&
          resource.data.status == 'draft'
        );
      }

      match /generalLedger/{glId} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        // Ledger rows are append-only.
        allow create: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        allow update, delete: if false;
      }

      // Recurring journal templates. The daily scheduler
      // (functions/src/accounting.ts) posts them with the Admin SDK; clients
      // only manage the templates themselves.
      match /recurringJournals/{templateId} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      // One doc per (template, fiscal period) — the idempotency guard the
      // recurring journal scheduler creates transactionally with each posting
      // (doc id: {templateId}_{YYYY-MM}; the Admin SDK bypasses these rules).
      // Clients only read them: reversing a posting is a manual journal task,
      // so no client update/delete — mirrors fixedAssetPostings.
      match /recurringJournalPostings/{postingId} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        allow create: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        allow update, delete: if isSuperAdmin();
      }

      // Fixed-asset register (the depreciation subledger).
      match /fixedAssets/{assetId} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      // One doc per posted depreciation period (YYYY-MM) — the idempotency
      // guard for fixedAssetService.postDepreciationForPeriod. Never edited
      // or deleted from clients: reversing a period is a manual journal task.
      match /fixedAssetPostings/{period} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        allow create: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        allow update, delete: if isSuperAdmin();
      }

      match /fiscalYears/{yearId} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /fiscalPeriods/{periodId} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /balanceSnapshots/{snapshotId} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        allow create, update: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        allow delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      // ============================================
      // ANNOUNCEMENTS SUBCOLLECTION (Ekipa)
      // ============================================
      match /announcements/{announcementId} {
        // All tenant members can read announcements
        allow read: if isSuperAdmin() || isTenantMember(tenantId);
        // Only admins can publish or edit announcement content.
        allow create, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
        allow update: if isSuperAdmin() || isTenantAdmin(tenantId) || (
          isTenantMember(tenantId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) &&
          request.resource.data.readBy is map &&
          request.resource.data.readBy
            .diff(resource.data.get('readBy', {}))
            .affectedKeys().hasOnly([request.auth.uid]) &&
          request.resource.data.readBy[request.auth.uid] == request.time
        );
      }

      // ============================================
      // EXPENSES SUBCOLLECTION (Employee reimbursements — Ekipa)
      // ============================================
      match /expenses/{expenseId} {
        allow read: if isSuperAdmin() ||
          isTenantManagerOrAdmin(tenantId) ||
          (resource.data.employeeId != null &&
           isSelfEmployee(tenantId, resource.data.employeeId));

        allow create: if isSuperAdmin() ||
          isTenantManagerOrAdmin(tenantId) ||
          (request.resource.data.employeeId != null &&
           isSelfEmployee(tenantId, request.resource.data.employeeId) &&
           // A staff member filing their own claim can only create it
           // 'submitted' — creating it already 'approved' is self-approval
           // (the update rule below already blocks the status change, so the
           // create path must too). Managers/admins keep full authority above.
           request.resource.data.get('status', 'submitted') == 'submitted');

        // Admins can approve/reject. Employees can update their own pending expenses
        // but CANNOT change status (prevents self-approval) or reassign employeeId
        allow update: if isSuperAdmin() || isTenantManagerOrAdmin(tenantId) || (
          resource.data.employeeId != null &&
          isSelfEmployee(tenantId, resource.data.employeeId) &&
          request.resource.data.employeeId == resource.data.employeeId &&
          resource.data.status == 'submitted' &&
          request.resource.data.status == 'submitted'
        );
        allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // RECOGNITION SUBCOLLECTION (Peer kudos — Ekipa)
      // ============================================
      match /recognition/{recognitionId} {
        // All tenant members can read and create recognition
        allow read: if isSuperAdmin() || isTenantMember(tenantId);
        allow create: if isSuperAdmin() || isTenantMember(tenantId);
        // Recognition is immutable once sent
        allow update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ============================================
      // GRIEVANCES SUBCOLLECTION (Anonymous — Ekipa)
      // ============================================
      match /grievances/{grievanceId} {
        // Only HR admins can list/read the confidential report body.
        allow read: if isSuperAdmin() || isTenantAdmin(tenantId);
        // Anonymous is enforced at the boundary: the employee client cannot
        // smuggle a uid/name/email into the document or forge its status.
        allow create: if isSuperAdmin() || (
          isTenantMember(tenantId) &&
          request.resource.data.keys().hasAll([
            'tenantId', 'ticketId', 'category', 'description',
            'attachmentUrls', 'status', 'createdAt'
          ]) &&
          request.resource.data.keys().hasOnly([
            'tenantId', 'ticketId', 'category', 'description',
            'attachmentUrls', 'status', 'createdAt'
          ]) &&
          request.resource.data.tenantId == tenantId &&
          grievanceId == request.resource.data.ticketId &&
          request.resource.data.ticketId is string &&
          request.resource.data.ticketId.size() == 16 &&
          request.resource.data.category in [
            'harassment', 'wage_issue', 'safety_concern',
            'discrimination', 'other'
          ] &&
          request.resource.data.description is string &&
          request.resource.data.description.size() >= 20 &&
          request.resource.data.description.size() <= 5000 &&
          request.resource.data.attachmentUrls is list &&
          request.resource.data.attachmentUrls.size() <= 3 &&
          request.resource.data.status == 'submitted' &&
          request.resource.data.createdAt == request.time &&
          existsAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievanceStatuses/$(grievanceId)) &&
          getAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievanceStatuses/$(grievanceId)).data.ticketId == grievanceId &&
          getAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievanceStatuses/$(grievanceId)).data.status == 'submitted'
        );
        allow update: if isSuperAdmin() || (
          isTenantAdmin(tenantId) &&
          request.resource.data.tenantId == resource.data.tenantId &&
          request.resource.data.ticketId == resource.data.ticketId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'resolution', 'resolvedAt', 'updatedAt'
          ]) &&
          request.resource.data.updatedAt == request.time &&
          existsAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievanceStatuses/$(grievanceId)) &&
          getAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievanceStatuses/$(grievanceId)).data.status == request.resource.data.status &&
          getAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievanceStatuses/$(grievanceId)).data.get('resolution', '') == request.resource.data.get('resolution', '') &&
          (
            (resource.data.status == 'submitted' && request.resource.data.status == 'reviewing') ||
            (
              resource.data.status in ['submitted', 'reviewing'] &&
              request.resource.data.status in ['resolved', 'dismissed'] &&
              request.resource.data.resolution is string &&
              request.resource.data.resolution.size() >= 10 &&
              request.resource.data.resolution.size() <= 2000 &&
              request.resource.data.resolvedAt == request.time
            )
          )
        );
        // Grievances should not be deleted
        allow delete: if isSuperAdmin();
      }

      // Token-bearer status mirror for Ekipa. Employees can get one exact,
      // unguessable ticket document but cannot list tickets or read grievance
      // descriptions. HR keeps this mirror in the same batch as status edits.
      match /grievanceStatuses/{ticketId} {
        allow get: if isSuperAdmin() || isTenantMember(tenantId);
        allow list: if isSuperAdmin() || isTenantAdmin(tenantId);
        allow create: if isSuperAdmin() || (
          request.resource.data.keys().hasAll([
            'tenantId', 'ticketId', 'category', 'status', 'createdAt', 'updatedAt'
          ]) &&
          request.resource.data.keys().hasOnly([
            'tenantId', 'ticketId', 'category', 'status', 'createdAt',
            'updatedAt', 'resolvedAt', 'resolution'
          ]) &&
          request.resource.data.tenantId == tenantId &&
          request.resource.data.ticketId == ticketId &&
          request.resource.data.ticketId is string &&
          request.resource.data.ticketId.size() == 16 &&
          request.resource.data.category in [
            'harassment', 'wage_issue', 'safety_concern',
            'discrimination', 'other'
          ] &&
          existsAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievances/$(ticketId)) &&
          getAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievances/$(ticketId)).data.ticketId == ticketId &&
          getAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievances/$(ticketId)).data.category == request.resource.data.category &&
          getAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievances/$(ticketId)).data.status == request.resource.data.status &&
          (
            isTenantAdmin(tenantId) || (
            isTenantMember(tenantId) &&
              request.resource.data.status == 'submitted' &&
              request.resource.data.createdAt == request.time &&
              request.resource.data.updatedAt == request.time &&
              !request.resource.data.keys().hasAny(['resolvedAt', 'resolution'])
            )
          )
        );
        allow update: if isSuperAdmin() || (
          isTenantAdmin(tenantId) &&
          request.resource.data.tenantId == resource.data.tenantId &&
          request.resource.data.ticketId == resource.data.ticketId &&
          request.resource.data.category == resource.data.category &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'resolution', 'resolvedAt', 'updatedAt'
          ]) &&
          request.resource.data.updatedAt == request.time &&
          existsAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievances/$(ticketId)) &&
          getAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievances/$(ticketId)).data.status == request.resource.data.status &&
          getAfter(/databases/$(database)/documents/tenants/$(tenantId)/grievances/$(ticketId)).data.get('resolution', '') == request.resource.data.get('resolution', '') &&
          (
            (resource.data.status == 'submitted' && request.resource.data.status == 'reviewing') ||
            (
              resource.data.status in ['submitted', 'reviewing'] &&
              request.resource.data.status in ['resolved', 'dismissed'] &&
              request.resource.data.resolution is string &&
              request.resource.data.resolution.size() >= 10 &&
              request.resource.data.resolution.size() <= 2000 &&
              request.resource.data.resolvedAt == request.time
            )
          )
        );
        allow delete: if isSuperAdmin();
      }

      // ============================================
      // SHIFTS SUBCOLLECTION (Ekipa reads published shifts)
      // ============================================
      match /shifts/{shiftId} {
        // Managers can plan their department roster. Employees only see their
        // own published shifts; drafts and coworkers' schedules stay private.
        allow read: if isSuperAdmin() || isTenantAdmin(tenantId) ||
          isManagerForDepartment(tenantId, resource.data.get('departmentId', null)) || (
          resource.data.employeeId != null &&
          resource.data.status == 'published' &&
          isSelfEmployee(tenantId, resource.data.employeeId)
        );
        // Shift content is created/edited by createOrUpdateShift so overlap,
        // rest-period, leave, and employee-scope validation cannot be bypassed.
        allow create: if isSuperAdmin();
        // Authorized planners may publish/cancel an already validated shift.
        allow update: if isSuperAdmin() || (
          (isTenantAdmin(tenantId) ||
           isManagerForDepartment(tenantId, resource.data.get('departmentId', null))) &&
          request.resource.data.departmentId == resource.data.departmentId &&
          request.resource.data.employeeId == resource.data.employeeId &&
          request.resource.data.status in ['draft', 'published', 'confirmed', 'cancelled'] &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        );
        allow delete: if isSuperAdmin() || isTenantAdmin(tenantId) ||
          isManagerForDepartment(tenantId, resource.data.get('departmentId', null));
      }

      // ============================================
      // EMPLOYEE SUBCOLLECTIONS (Document requests, Change requests)
      // ============================================
      match /employees/{employeeId}/document_requests/{requestId} {
        // Employee can read their own requests; admins can read all
        allow read: if isSuperAdmin() || canAccessStaffRecords(tenantId) || (
          isSelfEmployee(tenantId, employeeId)
        );
        // Employee can create requests for themselves
        allow create: if isSuperAdmin() || (
          isSelfEmployee(tenantId, employeeId)
        );
        // Only admins can update (mark ready/rejected)
        allow update: if isSuperAdmin() || canAccessStaffRecords(tenantId);
        allow delete: if isSuperAdmin();
      }

      match /employees/{employeeId}/change_requests/{requestId} {
        // Employee can read their own; admins can read all
        allow read: if isSuperAdmin() || canAccessStaffRecords(tenantId) || (
          isSelfEmployee(tenantId, employeeId)
        );
        // Employee can create change requests for themselves
        allow create: if isSuperAdmin() || (
          isSelfEmployee(tenantId, employeeId)
        );
        // Only admins can approve/reject
        allow update: if isSuperAdmin() || canAccessStaffRecords(tenantId);
        allow delete: if isSuperAdmin();
      }

      // ============================================
      // MONEY MODULE SUBCOLLECTIONS
      // ============================================
      match /customers/{customerId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /invoices/{invoiceId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);

        function validDraftCreate() {
          return request.resource.data.keys().hasAll([
              'invoiceNumber', 'customerId', 'customerName', 'issueDate',
              'dueDate', 'items', 'subtotal', 'taxRate', 'taxAmount', 'total',
              'status', 'amountPaid', 'balanceDue', 'currency', 'createdBy',
              'updatedBy', 'createdAt', 'updatedAt'
            ]) &&
            request.resource.data.status == 'draft' &&
            request.resource.data.currency == 'USD' &&
            request.resource.data.items is list &&
            request.resource.data.total is number &&
            request.resource.data.total >= 0 &&
            request.resource.data.amountPaid == 0 &&
            request.resource.data.get('creditedAmount', 0) == 0 &&
            moneyClose(request.resource.data.balanceDue, request.resource.data.total) &&
            request.resource.data.createdBy == request.auth.uid &&
            request.resource.data.updatedBy == request.auth.uid &&
            request.resource.data.createdAt is timestamp &&
            request.resource.data.updatedAt is timestamp;
        }

        function validDraftEdit() {
          return resource.data.status == 'draft' &&
            request.resource.data.status == 'draft' &&
            request.resource.data.createdBy == resource.data.createdBy &&
            request.resource.data.createdAt == resource.data.createdAt &&
            request.resource.data.amountPaid == 0 &&
            request.resource.data.get('creditedAmount', 0) == 0 &&
            moneyClose(request.resource.data.balanceDue, request.resource.data.total) &&
            request.resource.data.updatedBy == request.auth.uid &&
            request.resource.data.updatedAt == request.time &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'customerId', 'customerName', 'customerEmail', 'customerPhone',
              'customerAddress', 'customerVatId', 'issueDate', 'dueDate',
              'items', 'projectName', 'poNumber', 'subtotal', 'discountTotal',
              'taxRate', 'taxAmount', 'total', 'balanceDue', 'vatBreakdown',
              'isVATInvoice', 'supplierVatId', 'notes', 'terms', 'templateId',
              'accentColor', 'paymentTermsDays', 'paymentMethods',
              'paymentAccount', 'updatedBy', 'updatedAt'
            ]);
        }

        function validIssue() {
          return resource.data.status == 'draft' &&
            request.resource.data.status == 'sent' &&
            request.resource.data.amountPaid == resource.data.amountPaid &&
            request.resource.data.get('creditedAmount', 0) == resource.data.get('creditedAmount', 0) &&
            request.resource.data.balanceDue == resource.data.balanceDue &&
            request.resource.data.sentAt == request.time &&
            request.resource.data.deliveryStatus == 'preparing' &&
            request.resource.data.deliveryAttemptedBy == request.auth.uid &&
            request.resource.data.updatedBy == request.auth.uid &&
            request.resource.data.updatedAt == request.time &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'sentAt', 'deliveryStatus', 'deliveryAttemptedBy',
              'deliveryUpdatedAt', 'journalEntryId', 'updatedBy', 'updatedAt'
            ]);
        }

        function validMetadataUpdate() {
          return request.resource.data.status == resource.data.status &&
            request.resource.data.updatedBy == request.auth.uid &&
            request.resource.data.updatedAt == request.time &&
            request.resource.data.get('deliveryStatus', 'not_requested') in [
              'not_requested', 'preparing', 'queued', 'sent', 'failed', 'no_email'
            ] &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'templateId', 'accentColor', 'shareToken', 'sentPdfUrl',
              'deliveryStatus', 'deliveryError', 'deliveryUpdatedAt',
              'emailQueuedAt', 'emailSentAt', 'deliveryAttemptedBy',
              'deliveryAttemptId', 'lastReminderAt', 'reminderCount',
              'journalEntryId', 'updatedBy', 'updatedAt'
            ]);
        }

        function validOverdueUpdate() {
          return resource.data.status in ['sent', 'viewed', 'partial'] &&
            request.resource.data.status == 'overdue' &&
            request.resource.data.balanceDue > 0 &&
            request.resource.data.updatedBy == request.auth.uid &&
            request.resource.data.updatedAt == request.time &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'updatedBy', 'updatedAt'
            ]);
        }

        function validPaymentUpdate() {
          let paymentId = request.resource.data.get('lastPaymentId', '');
          let payment = getAfter(/databases/$(database)/documents/tenants/$(tenantId)/payments_received/$(paymentId)).data;
          return resource.data.status in ['sent', 'viewed', 'partial', 'overdue'] &&
            paymentId != '' &&
            payment.kind == 'payment' &&
            payment.invoiceId == invoiceId &&
            payment.createdBy == request.auth.uid &&
            payment.amount > 0 &&
            payment.amount <= resource.data.balanceDue + 0.00001 &&
            request.resource.data.get('creditedAmount', 0) == resource.data.get('creditedAmount', 0) &&
            moneyClose(request.resource.data.amountPaid, resource.data.amountPaid + payment.amount) &&
            moneyClose(request.resource.data.balanceDue, resource.data.balanceDue - payment.amount) &&
            request.resource.data.balanceDue >= 0 &&
            ((moneyClose(request.resource.data.balanceDue, 0) && request.resource.data.status == 'paid') ||
             (request.resource.data.balanceDue > 0 && request.resource.data.status == 'partial')) &&
            request.resource.data.updatedBy == request.auth.uid &&
            request.resource.data.updatedAt == request.time &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'amountPaid', 'balanceDue', 'status', 'paidAt', 'lastPaymentId',
              'updatedBy', 'updatedAt'
            ]);
        }

        function validRefundUpdate() {
          let refundId = request.resource.data.get('lastRefundId', '');
          let refund = getAfter(/databases/$(database)/documents/tenants/$(tenantId)/payments_received/$(refundId)).data;
          return resource.data.status in ['sent', 'viewed', 'paid', 'partial', 'overdue'] &&
            refundId != '' &&
            refund.kind == 'refund' &&
            refund.invoiceId == invoiceId &&
            refund.createdBy == request.auth.uid &&
            refund.amount < 0 &&
            request.resource.data.get('creditedAmount', 0) == resource.data.get('creditedAmount', 0) &&
            moneyClose(request.resource.data.amountPaid, resource.data.amountPaid + refund.amount) &&
            moneyClose(request.resource.data.balanceDue, resource.data.balanceDue - refund.amount) &&
            request.resource.data.amountPaid >= 0 &&
            request.resource.data.balanceDue > 0 &&
            request.resource.data.status in ['sent', 'viewed', 'partial', 'overdue'] &&
            request.resource.data.updatedBy == request.auth.uid &&
            request.resource.data.updatedAt == request.time &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'amountPaid', 'balanceDue', 'status', 'paidAt', 'lastRefundId',
              'updatedBy', 'updatedAt'
            ]);
        }

        function validCreditUpdate() {
          let creditId = request.resource.data.get('lastCreditNoteId', '');
          let credit = getAfter(/databases/$(database)/documents/tenants/$(tenantId)/credit_notes/$(creditId)).data;
          let newCreditTotal = resource.data.get('creditedAmount', 0) + credit.amount;
          return resource.data.status in ['sent', 'viewed', 'paid', 'partial', 'overdue'] &&
            creditId != '' &&
            credit.invoiceId == invoiceId &&
            credit.status == 'issued' &&
            credit.createdBy == request.auth.uid &&
            credit.amount > 0 &&
            credit.amount <= resource.data.balanceDue + 0.00001 &&
            request.resource.data.amountPaid == resource.data.amountPaid &&
            moneyClose(request.resource.data.creditedAmount, newCreditTotal) &&
            moneyClose(request.resource.data.get('creditedTaxAmount', 0), resource.data.get('creditedTaxAmount', 0) + credit.taxAmount) &&
            moneyClose(request.resource.data.balanceDue, resource.data.balanceDue - credit.amount) &&
            request.resource.data.creditNoteCount == resource.data.get('creditNoteCount', 0) + 1 &&
            request.resource.data.balanceDue >= 0 &&
            ((moneyClose(request.resource.data.balanceDue, 0) && resource.data.amountPaid > 0 && request.resource.data.status == 'paid') ||
             (moneyClose(request.resource.data.balanceDue, 0) && resource.data.amountPaid == 0 && request.resource.data.status == 'credited') ||
             (request.resource.data.balanceDue > 0 && request.resource.data.status == 'partial')) &&
            request.resource.data.updatedBy == request.auth.uid &&
            request.resource.data.updatedAt == request.time &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'creditedAmount', 'creditedTaxAmount', 'balanceDue', 'status',
              'paidAt', 'creditNoteCount', 'lastCreditNoteId', 'updatedBy',
              'updatedAt'
            ]);
        }

        function validCancellation() {
          return resource.data.status in ['sent', 'viewed', 'partial', 'overdue'] &&
            resource.data.amountPaid == 0 &&
            resource.data.get('creditedAmount', 0) == 0 &&
            request.resource.data.status == 'cancelled' &&
            request.resource.data.cancelReason is string &&
            request.resource.data.cancelReason.size() > 0 &&
            request.resource.data.cancelledAt == request.time &&
            request.resource.data.updatedBy == request.auth.uid &&
            request.resource.data.updatedAt == request.time &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'cancelledAt', 'cancelReason',
              'cancellationAdjustmentEntryId', 'updatedBy', 'updatedAt'
            ]);
        }

        allow create: if isSuperAdmin() ||
          (isTenantFinanceAdmin(tenantId) && validDraftCreate());
        allow update: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) && (
            validDraftEdit() || validIssue() || validMetadataUpdate() ||
            validOverdueUpdate() || validPaymentUpdate() ||
            validRefundUpdate() || validCreditUpdate() || validCancellation()
          )
        );
        allow delete: if isSuperAdmin() ||
          (isTenantFinanceAdmin(tenantId) && resource.data.status == 'draft');
      }

      match /payments_received/{paymentId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);

        function validReceiptCreate() {
          let invoiceId = request.resource.data.get('invoiceId', '');
          let invoice = getAfter(/databases/$(database)/documents/tenants/$(tenantId)/invoices/$(invoiceId)).data;
          return request.resource.data.kind == 'payment' &&
            invoiceId != '' &&
            request.resource.data.amount is number &&
            request.resource.data.amount > 0 &&
            request.resource.data.date is string &&
            request.resource.data.createdBy == request.auth.uid &&
            request.resource.data.createdAt is timestamp &&
            request.resource.data.get('refundedAmount', 0) == 0 &&
            request.resource.data.get('refundStatus', 'none') == 'none' &&
            invoice.lastPaymentId == paymentId &&
            invoice.customerId == request.resource.data.customerId &&
            invoice.invoiceNumber == request.resource.data.invoiceNumber;
        }

        function validRefundCreate() {
          let invoiceId = request.resource.data.get('invoiceId', '');
          let originalId = request.resource.data.get('relatedPaymentId', '');
          let original = get(/databases/$(database)/documents/tenants/$(tenantId)/payments_received/$(originalId)).data;
          let originalAfter = getAfter(/databases/$(database)/documents/tenants/$(tenantId)/payments_received/$(originalId)).data;
          let invoiceAfter = getAfter(/databases/$(database)/documents/tenants/$(tenantId)/invoices/$(invoiceId)).data;
          return request.resource.data.kind == 'refund' &&
            invoiceId != '' && originalId != '' &&
            original.kind == 'payment' &&
            original.invoiceId == invoiceId &&
            request.resource.data.amount is number &&
            request.resource.data.amount < 0 &&
            0 - request.resource.data.amount <= original.amount - original.get('refundedAmount', 0) + 0.00001 &&
            request.resource.data.date is string &&
            request.resource.data.notes is string &&
            request.resource.data.notes.size() > 0 &&
            request.resource.data.createdBy == request.auth.uid &&
            request.resource.data.createdAt is timestamp &&
            originalAfter.lastRefundId == paymentId &&
            moneyClose(originalAfter.refundedAmount, original.get('refundedAmount', 0) - request.resource.data.amount) &&
            invoiceAfter.lastRefundId == paymentId;
        }

        function validReceiptRefundMetadata() {
          let refundId = request.resource.data.get('lastRefundId', '');
          let refund = getAfter(/databases/$(database)/documents/tenants/$(tenantId)/payments_received/$(refundId)).data;
          return resource.data.kind == 'payment' &&
            refundId != '' &&
            refund.kind == 'refund' &&
            refund.relatedPaymentId == paymentId &&
            refund.invoiceId == resource.data.invoiceId &&
            refund.createdBy == request.auth.uid &&
            moneyClose(request.resource.data.refundedAmount, resource.data.get('refundedAmount', 0) - refund.amount) &&
            request.resource.data.refundedAmount <= resource.data.amount + 0.00001 &&
            ((moneyClose(request.resource.data.refundedAmount, resource.data.amount) && request.resource.data.refundStatus == 'refunded') ||
             (request.resource.data.refundedAmount < resource.data.amount && request.resource.data.refundStatus == 'partial')) &&
            request.resource.data.updatedAt == request.time &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'refundedAmount', 'refundStatus', 'lastRefundId', 'updatedAt'
            ]);
        }

        allow create: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) &&
          (validReceiptCreate() || validRefundCreate())
        );
        allow update: if isSuperAdmin() ||
          (isTenantFinanceAdmin(tenantId) && validReceiptRefundMetadata());
        allow delete: if false;
      }

      match /credit_notes/{creditNoteId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);

        function validCreditNoteCreate() {
          let invoiceId = request.resource.data.get('invoiceId', '');
          let invoiceBefore = get(/databases/$(database)/documents/tenants/$(tenantId)/invoices/$(invoiceId)).data;
          let invoiceAfter = getAfter(/databases/$(database)/documents/tenants/$(tenantId)/invoices/$(invoiceId)).data;
          return invoiceId != '' &&
            request.resource.data.creditNoteNumber is string &&
            request.resource.data.creditNoteNumber.size() > 0 &&
            request.resource.data.invoiceNumber == invoiceBefore.invoiceNumber &&
            request.resource.data.customerId == invoiceBefore.customerId &&
            request.resource.data.amount is number &&
            request.resource.data.amount > 0 &&
            request.resource.data.amount <= invoiceBefore.balanceDue + 0.00001 &&
            request.resource.data.netAmount is number &&
            request.resource.data.netAmount >= 0 &&
            request.resource.data.taxAmount is number &&
            request.resource.data.taxAmount >= 0 &&
            moneyClose(request.resource.data.netAmount + request.resource.data.taxAmount, request.resource.data.amount) &&
            request.resource.data.reason is string &&
            request.resource.data.reason.size() > 0 &&
            request.resource.data.status == 'issued' &&
            request.resource.data.createdBy == request.auth.uid &&
            request.resource.data.createdAt is timestamp &&
            invoiceAfter.lastCreditNoteId == creditNoteId;
        }

        allow create: if isSuperAdmin() ||
          (isTenantFinanceAdmin(tenantId) && validCreditNoteCreate());
        allow update, delete: if false;
      }

      match /recurring_invoices/{recurringId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /vendors/{vendorId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /bills/{billId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /bill_payments/{paymentId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /supplierWithholdingPeriods/{periodId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId) || canAccessPayrollRecords(tenantId);
        allow create, update: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        allow delete: if false;
      }

      match /supplierWithholdingRemittances/{remittanceId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId) || canAccessPayrollRecords(tenantId);
        // Payment records are evidence and immutable after the atomic posting.
        allow create: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        allow update, delete: if false;
      }

      match /taxClearanceRequests/{requestId} {
        allow read: if isSuperAdmin() || canAccessAccountingRecords(tenantId);
        allow create, update: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        allow delete: if false;
      }

      match /cashAdvances/{advanceId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        allow update: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'expenseCleared',
            'cashReturned',
            'outstanding',
            'status',
            'updatedAt'
          ])
        );
        allow delete: if false;
      }

      match /cashAdvanceClearings/{clearingId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
        allow update, delete: if false;
      }

      // ============================================
      // KAIXA POS + CASH TRACKING
      // ============================================
      match /transactions/{transactionId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) &&
          request.resource.data.tenantId == tenantId &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.type in ['in', 'out'] &&
          request.resource.data.amount is number &&
          request.resource.data.amount > 0
        );
        // Financial values stay immutable. Kaixa may only attach receipt/sync metadata.
        allow update: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) &&
          resource.data.tenantId == tenantId &&
          request.resource.data.tenantId == resource.data.tenantId &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'receiptNumber',
            'customerVatId',
            'syncedToMeza',
            'mezaInvoiceId',
            'updatedAt',
          ])
        );
        allow delete: if false;
      }

      match /products/{productId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /customerTabs/{tabId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /receiptCounters/{year} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) &&
          request.resource.data.year == year &&
          request.resource.data.seq == 1
        );
        allow update: if isSuperAdmin() || (
          isTenantFinanceAdmin(tenantId) &&
          request.resource.data.year == resource.data.year &&
          request.resource.data.seq == resource.data.seq + 1 &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'seq',
            'year',
            'updatedAt',
          ])
        );
        allow delete: if false;
      }

      match /vatReturns/{periodId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      match /bankTransactions/{txId} {
        allow read: if isSuperAdmin() || canAccessMoneyRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantFinanceAdmin(tenantId);
      }

      // ============================================
      // OTHER TENANT SUBCOLLECTIONS
      // ============================================
      match /holidays/{holidayId} {
        allow read: if isSuperAdmin() || isTenantMember(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      match /analytics/{docId} {
        allow read: if isSuperAdmin() || hasTenantModule(tenantId, 'reports');
        allow create, update: if isSuperAdmin() || isTenantAdmin(tenantId);
        allow delete: if isSuperAdmin();
      }

      // Saved custom report configs (Reports > Custom Reports). These are
      // report DEFINITIONS only — name, data source, column keys, filter
      // values — never employee data; the data itself is fetched live under
      // its own collections' rules. Shared tenant assets: anyone who can use
      // the Reports module (module members, managers, admins — mirrors the
      // /reports/custom route gate) can manage them, strictly tenant-scoped.
      match /customReports/{reportId} {
        allow read: if isSuperAdmin() || isTenantManagerOrAdmin(tenantId) ||
          hasTenantModule(tenantId, 'reports');
        // createdBy must name the caller — a member cannot attribute a saved
        // report to someone else.
        allow create: if isSuperAdmin() || (
          (isTenantManagerOrAdmin(tenantId) || hasTenantModule(tenantId, 'reports')) &&
          request.resource.data.createdBy == request.auth.uid
        );
        // createdBy is immutable; otherwise the same group shares maintenance
        // (rename, lastRunAt stamping) of the tenant's saved reports.
        allow update: if isSuperAdmin() || (
          (isTenantManagerOrAdmin(tenantId) || hasTenantModule(tenantId, 'reports')) &&
          request.resource.data.createdBy == resource.data.createdBy
        );
        allow delete: if isSuperAdmin() || isTenantManagerOrAdmin(tenantId) ||
          hasTenantModule(tenantId, 'reports');
      }

      match /offers/{offerId} {
        allow read: if isSuperAdmin() || canAccessHiringRecords(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      match /employmentSnapshots/{snapshotId} {
        allow read: if isSuperAdmin() ||
          canAccessHiringRecords(tenantId) ||
          canAccessStaffRecords(tenantId);
        allow create, update: if isSuperAdmin() || isTenantAdmin(tenantId);
        allow delete: if isSuperAdmin();
      }

      match /leavePolicies/{policyId} {
        allow read: if isSuperAdmin() || isTenantMember(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      match /leaveBalances/{balanceId} {
        // Retired schema. Canonical balances live in top-level /leave_balances.
        allow read, write: if isSuperAdmin();
      }

      // ============================================
      // FACE RECOGNITION EMBEDDINGS
      // ============================================
      match /face_embeddings/{empId} {
        allow read: if isSuperAdmin() ||
          canAccessStaffRecords(tenantId) ||
          isSelfEmployee(tenantId, empId);
        allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // DEFAULT DENY: Any tenant subcollection not explicitly listed above
      // is blocked by Firestore's default-deny behavior. Do NOT add a catch-all
      // wildcard here — new subcollections must have explicit rules added.
    }

    // ============================================
    // PLATFORM CONFIG (Global)
    // ============================================
    match /platform/vatConfig {
      // Readable by any authenticated user (used to gate VAT UI)
      allow read: if isAuthenticated();
      // Only superadmins can enable/disable platform VAT
      allow write: if isSuperAdmin();
    }

    // ============================================
    // REFERENCE DATA (Global, read-only for users)
    // ============================================
    match /reference/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================
    // CONTRACT TEMPLATES (Global)
    // Uploaded by superadmins, readable by any signed-in user so tenants
    // can generate work contracts when adding employees.
    // ============================================
    match /contractTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================
    // LEGACY COLLECTIONS (for migration)
    // These collections store tenantId on each document.
    // SECURITY: Enforce tenant isolation via tenantId field checks.
    // TODO: Migrate to tenant-scoped paths under /tenants/{tenantId}/
    // ============================================
    match /employees/{employeeId} {
      // Legacy global collection is no longer used by the app; restrict to superadmins.
      allow read, write: if isSuperAdmin();
    }

    match /departments/{departmentId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantMember(resource.data.tenantId));
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantAdmin(resource.data.tenantId)
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
    }

    match /candidates/{candidateId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && canAccessHiringRecords(resource.data.tenantId));
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && canAccessHiringRecords(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        canAccessHiringRecords(resource.data.tenantId)
      );
      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );
    }

    match /jobs/{jobId} {
      // Public can read jobs that are currently open (for the candidate apply page).
      // Full tenant staff can read all jobs regardless of status.
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && canAccessHiringRecords(resource.data.tenantId)) ||
        resource.data.status == 'open';
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && canAccessHiringRecords(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        canAccessHiringRecords(resource.data.tenantId)
      );
      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );
    }

    match /interviews/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && canAccessHiringRecords(resource.data.tenantId));
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && canAccessHiringRecords(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        canAccessHiringRecords(resource.data.tenantId)
      );
      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );
    }

    match /jobPrivateDetails/{jobId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && canAccessHiringRecords(resource.data.tenantId));
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && canAccessHiringRecords(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        canAccessHiringRecords(resource.data.tenantId)
      );
      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );
    }

    match /tenant_settings/{docId} {
      // Legacy (pre-tenant-scoped) settings were keyed by tenantId as the document id.
      allow read: if isSuperAdmin() || isTenantMember(docId);
      allow write: if isSuperAdmin() || isTenantAdmin(docId);
    }

    match /leave_requests/{docId} {
      allow read: if isSuperAdmin() || (
        resource.data.tenantId != null && (
          isTenantFinanceAdmin(resource.data.tenantId) ||
          isManagerForDepartment(
            resource.data.tenantId,
            resource.data.get('departmentId', null)
          ) ||
          (resource.data.employeeId != null &&
           isSelfEmployee(resource.data.tenantId, resource.data.employeeId))
        )
      );
      // Creation goes through createLeaveRequest so employee/department,
      // duration, holidays, policy, and overlap checks are server-owned.
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        resource.data.employeeId != null &&
        isSelfEmployee(resource.data.tenantId, resource.data.employeeId) &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );
    }

    match /leave_balances/{docId} {
      allow read: if isSuperAdmin() || (
        resource.data.tenantId != null && (
          isTenantFinanceAdmin(resource.data.tenantId) ||
          isManagerForDepartment(
            resource.data.tenantId,
            resource.data.get('departmentId', null)
          ) ||
          (resource.data.employeeId != null &&
           isSelfEmployee(resource.data.tenantId, resource.data.employeeId))
        )
      );
      // Balances are projections maintained by onLeaveRequestWrite.
      allow create, update, delete: if isSuperAdmin();
    }

    match /timesheets/{docId} {
      allow read: if isSuperAdmin() || (
        resource.data.tenantId != null && (
          isTenantFinanceAdmin(resource.data.tenantId) ||
          (resource.data.employeeId != null &&
           isSelfEmployee(resource.data.tenantId, resource.data.employeeId))
        )
      );
      allow create, update, delete: if isSuperAdmin();
    }

    match /okrs/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantAdmin(resource.data.tenantId)
      );
      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );
    }

    match /goals/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantAdmin(resource.data.tenantId)
      );
      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );
    }

    match /reviews/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && (
          isTenantAdmin(resource.data.tenantId) ||
          (resource.data.employeeId != null &&
           resource.data.status != 'draft' &&
           isSelfEmployee(resource.data.tenantId, resource.data.employeeId))
        ));
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId && (
          isTenantAdmin(resource.data.tenantId) || (
            resource.data.employeeId != null &&
            isSelfEmployee(resource.data.tenantId, resource.data.employeeId) &&
            resource.data.status == 'submitted' &&
            request.resource.data.status == 'acknowledged' &&
            request.resource.data.employeeId == resource.data.employeeId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'employeeComments', 'acknowledgedAt', 'updatedAt'
            ]) &&
            request.resource.data.employeeComments is string &&
            request.resource.data.employeeComments.size() <= 2000 &&
            request.resource.data.acknowledgedAt == request.time &&
            request.resource.data.updatedAt == request.time
          )
        )
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
    }

    match /trainings/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && (
          isTenantAdmin(resource.data.tenantId) ||
          (resource.data.employeeId != null &&
           isSelfEmployee(resource.data.tenantId, resource.data.employeeId))
        ));
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantAdmin(resource.data.tenantId)
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
    }

    match /disciplinary/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
      allow create: if isSuperAdmin() || (
        request.resource.data.tenantId != null &&
        isTenantAdmin(request.resource.data.tenantId) &&
        request.resource.data.status == 'open'
      );
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantAdmin(resource.data.tenantId) &&
        resource.data.status != 'closed' &&
        (
          request.resource.data.status == resource.data.status ||
          (resource.data.status == 'open' && request.resource.data.status == 'in_review') ||
          (
            resource.data.status == 'in_review' &&
            request.resource.data.status == 'closed' &&
            request.resource.data.closedBy is string &&
            request.resource.data.closedBy.size() > 0 &&
            request.resource.data.closedDate is string &&
            (
              request.resource.data.type != 'termination' ||
              (
                request.resource.data.writtenAccusation is string &&
                request.resource.data.writtenAccusation.size() > 0 &&
                request.resource.data.employeeDefence is string &&
                request.resource.data.employeeDefence.size() > 0 &&
                request.resource.data.reasonedDecision is string &&
                request.resource.data.reasonedDecision.size() > 0 &&
                request.resource.data.decisionDeliveredDate is string &&
                request.resource.data.decisionDeliveredDate.size() > 0
              )
            )
          )
        )
      );
      // HR case records are retained as an audit trail.
      allow delete: if isSuperAdmin();
    }

    match /payruns/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && canAccessPayrollRecords(resource.data.tenantId));
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantAdmin(resource.data.tenantId) &&
        // Prevent createdBy tampering + two-person approval rule
        // (unless tenant opted in to solo self-approval)
        request.resource.data.createdBy == resource.data.createdBy &&
        (request.resource.data.status != 'approved' ||
         request.resource.data.approvedBy != resource.data.createdBy ||
         allowsSelfApproval(resource.data.tenantId)) &&
        // Paywall: the transition INTO 'approved' requires an active
        // subscription (already-approved runs stay editable if it lapses)
        (request.resource.data.status != 'approved' ||
         resource.data.status == 'approved' ||
         tenantHasActiveSubscription(resource.data.tenantId))
      );
      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );

      match /payslips/{payslipId} {
        allow read: if isSuperAdmin() ||
          (get(/databases/$(database)/documents/payruns/$(docId)).data.tenantId != null && (
            canAccessPayrollRecords(get(/databases/$(database)/documents/payruns/$(docId)).data.tenantId) ||
            isSelfEmployee(get(/databases/$(database)/documents/payruns/$(docId)).data.tenantId, payslipId) ||
            (resource.data.employeeId != null &&
             isSelfEmployee(
               get(/databases/$(database)/documents/payruns/$(docId)).data.tenantId,
               resource.data.employeeId
             ))
          ));
        allow write: if isSuperAdmin() ||
          (get(/databases/$(database)/documents/payruns/$(docId)).data.tenantId != null &&
           isTenantAdmin(get(/databases/$(database)/documents/payruns/$(docId)).data.tenantId));
      }
    }

    // Payroll module collections
    match /payrollRuns/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && canAccessPayrollRecords(resource.data.tenantId));

      allow create: if isSuperAdmin() || (
        request.resource.data.tenantId != null &&
        isTenantFinanceAdmin(request.resource.data.tenantId) &&
        // Create only in a pre-approval state. The transition INTO 'approved'
        // (and paid/cancelled/rejected) must go through the update rule so the
        // two-person approval rule, finalize paywall, and state machine all
        // apply — creating an already-'approved' run would bypass all three.
        !(request.resource.data.get('status', 'draft') in ['approved', 'paid', 'cancelled', 'rejected']) &&
        // Bind createdBy to the caller so the two-person rule
        // (approvedBy != createdBy) can't be defeated by forging the creator.
        request.resource.data.createdBy == request.auth.uid
      );

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantFinanceAdmin(resource.data.tenantId) &&
        // Prevent createdBy tampering - field is immutable after creation
        request.resource.data.createdBy == resource.data.createdBy &&
        // Two-person rule: approver must differ from creator
        // (unless tenant opted in to solo self-approval)
        (request.resource.data.status != 'approved' ||
         request.resource.data.approvedBy != resource.data.createdBy ||
         allowsSelfApproval(resource.data.tenantId)) &&
        // Paywall: the transition INTO 'approved' requires an active
        // subscription (already-approved runs stay editable if it lapses)
        (request.resource.data.status != 'approved' ||
         resource.data.status == 'approved' ||
         tenantHasActiveSubscription(resource.data.tenantId)) &&
        // State machine: never resurrect a finalized/void run to 'approved'.
        // Moving INTO 'approved' is allowed from any pre-approval state
        // (draft/processing/pending_approval/...); an already-approved run
        // stays editable; but paid/cancelled/rejected runs cannot become
        // approved. The exact-once concurrency guard is the transaction in
        // payrollService.approvePayrollRun.
        (request.resource.data.status != 'approved' ||
         resource.data.status == 'approved' ||
         (resource.data.status != 'paid' &&
          resource.data.status != 'cancelled' &&
          resource.data.status != 'rejected')) &&
        // A run becomes paid only from approved (or repairs a legacy paid run),
        // and only together with the cash-settlement evidence/link. This blocks
        // a direct draft -> paid update that would bypass approval and leave the
        // salary payable/cash accounts untouched.
        (request.resource.data.status != 'paid' ||
         ((resource.data.status == 'approved' || resource.data.status == 'paid') &&
          request.resource.data.settlementJournalEntryId is string &&
          request.resource.data.settlementJournalEntryId.size() > 0 &&
          request.resource.data.paymentDate is string &&
          request.resource.data.paymentDate.size() == 10 &&
          request.resource.data.paymentReference is string &&
          request.resource.data.paymentReference.size() > 0 &&
          request.resource.data.paidBy == request.auth.uid)) &&
        // Once linked, settlement evidence is immutable. Corrections belong in
        // reversing journals, never by silently pointing the run elsewhere.
        (resource.data.get('settlementJournalEntryId', null) == null ||
         (request.resource.data.settlementJournalEntryId == resource.data.settlementJournalEntryId &&
          request.resource.data.paymentDate == resource.data.paymentDate &&
          request.resource.data.paymentReference == resource.data.paymentReference &&
          request.resource.data.paidBy == resource.data.paidBy))
      );

      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantFinanceAdmin(resource.data.tenantId)
      );
    }

    match /payrollRecords/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && (
          canAccessPayrollRecords(resource.data.tenantId) ||
          (resource.data.employeeId != null &&
           isSelfEmployee(resource.data.tenantId, resource.data.employeeId))
        ));

      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantFinanceAdmin(request.resource.data.tenantId));

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantFinanceAdmin(resource.data.tenantId)
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantFinanceAdmin(resource.data.tenantId));
    }

    match /benefitEnrollments/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && (
          canAccessPayrollRecords(resource.data.tenantId) ||
          (resource.data.employeeId != null &&
           isSelfEmployee(resource.data.tenantId, resource.data.employeeId))
        ));

      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantFinanceAdmin(request.resource.data.tenantId));

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantFinanceAdmin(resource.data.tenantId)
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantFinanceAdmin(resource.data.tenantId));
    }

    match /recurringDeductions/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && (
          canAccessPayrollRecords(resource.data.tenantId) ||
          (resource.data.employeeId != null &&
           isSelfEmployee(resource.data.tenantId, resource.data.employeeId))
        ));

      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantFinanceAdmin(request.resource.data.tenantId));

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantFinanceAdmin(resource.data.tenantId)
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantFinanceAdmin(resource.data.tenantId));
    }

    match /taxReports/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && canAccessPayrollRecords(resource.data.tenantId));

      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantFinanceAdmin(request.resource.data.tenantId));

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantFinanceAdmin(resource.data.tenantId)
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantFinanceAdmin(resource.data.tenantId));
    }

    match /bankTransfers/{docId} {
      // createTransfer claims a deterministic tenant/run id in a transaction.
      // Firestore evaluates the transaction's read before its create, so an
      // authenticated caller must be able to observe that the target does not
      // exist. Existing documents remain tenant-scoped, and list queries still
      // evaluate each returned document against that tenant boundary.
      allow get: if (resource == null && isAuthenticated()) ||
        isSuperAdmin() ||
        (resource.data.tenantId != null && canAccessPayrollRecords(resource.data.tenantId));
      allow list: if isSuperAdmin() ||
        (resource.data.tenantId != null && canAccessPayrollRecords(resource.data.tenantId));

      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantFinanceAdmin(request.resource.data.tenantId));

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantFinanceAdmin(resource.data.tenantId)
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantFinanceAdmin(resource.data.tenantId));
    }

    // Statutory filings: Payroll owns wage WIT/INSS; Accounting owns business tax.
    match /taxFilings/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && (
          (
            canAccessAccountingRecords(resource.data.tenantId) &&
            resource.data.type in ['annual_income_tax', 'services_tax', 'installment_tax']
          ) ||
          (
            canAccessPayrollRecords(resource.data.tenantId) &&
            !(resource.data.type in ['annual_income_tax', 'services_tax', 'installment_tax'])
          )
        ));

      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantFinanceAdmin(request.resource.data.tenantId));

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantFinanceAdmin(resource.data.tenantId)
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantFinanceAdmin(resource.data.tenantId));
    }

    // Attendance tracking
    match /attendance/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && (
          isTenantFinanceAdmin(resource.data.tenantId) ||
          isManagerForDepartment(
            resource.data.tenantId,
            resource.data.get('departmentId', null)
          ) ||
          (resource.data.employeeId != null &&
           isSelfEmployee(resource.data.tenantId, resource.data.employeeId))
        ));

      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && (
          (
            request.resource.data.source == 'supervisor' &&
            (
              isTenantAdmin(request.resource.data.tenantId) ||
              (
                isManagerForDepartment(
                  request.resource.data.tenantId,
                  request.resource.data.get('departmentId', null)
                ) &&
                employeeInDepartment(
                  request.resource.data.tenantId,
                  request.resource.data.get('employeeId', null),
                  request.resource.data.get('departmentId', null)
                )
              )
            ) &&
            request.resource.data.supervisorId == request.auth.uid
          ) ||
          (
            request.resource.data.source != 'supervisor' &&
            (
              isTenantAdmin(request.resource.data.tenantId) ||
              (
                isManagerForDepartment(
                  request.resource.data.tenantId,
                  request.resource.data.get('departmentId', null)
                ) &&
                employeeInDepartment(
                  request.resource.data.tenantId,
                  request.resource.data.get('employeeId', null),
                  request.resource.data.get('departmentId', null)
                )
              )
            )
          )
        ));

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        (isTenantAdmin(resource.data.tenantId) ||
         (
           isManagerForDepartment(
             resource.data.tenantId,
             resource.data.get('departmentId', null)
           ) &&
           request.resource.data.get('departmentId', null) ==
             resource.data.get('departmentId', null) &&
           request.resource.data.get('employeeId', null) ==
             resource.data.get('employeeId', null)
         ))
      );

      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        (
          isTenantAdmin(resource.data.tenantId) ||
          isManagerForDepartment(
            resource.data.tenantId,
            resource.data.get('departmentId', null)
          )
        )
      );
    }

    // Attendance import batches
    match /attendanceImports/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantFinanceAdmin(resource.data.tenantId));

      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId));

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantAdmin(resource.data.tenantId)
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
    }

    // Accounting module collections
    match /accounts/{docId} {
      // Legacy global accounting collections are no longer used by the app; restrict to superadmins.
      allow read, write: if isSuperAdmin();
    }

    match /journalEntries/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /generalLedger/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /fiscalYears/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /fiscalPeriods/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /settings/{docId} {
      // Legacy global settings collection is no longer used by the app; restrict to superadmins.
      allow read, write: if isSuperAdmin();
    }

    // ============================================
    // HR ADMINS (tenant-scoped admin records)
    // ============================================
    match /hr_admins/{adminId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantMember(resource.data.tenantId));
      allow create: if isSuperAdmin() ||
        (request.resource.data.tenantId != null && isTenantAdmin(request.resource.data.tenantId));
      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantAdmin(resource.data.tenantId)
      );
      // Deletes have no request.resource — a combined update/delete rule
      // referencing it rejects every non-superadmin delete.
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));
    }

    // ============================================
    // EMAIL QUEUE (Firebase Trigger Email extension)
    // ============================================
    match /mail/{emailId} {
      // Tenant admins AND managers can queue emails for their tenant
      // (managers approve/reject leave, which emails the staff member).
      // Accountants queue invoice/payslip emails.
      // Recipients can't be fully validated in rules (per-address cross-collection
      // lookups aren't feasible), so instead pin the shape the ONLY sanctioned
      // writer — notificationService.queueEmail — produces: a purpose tag, a
      // 'pending' status, and a bounded recipient list. This blocks a manager
      // from hand-rolling an arbitrary blast and from injecting a non-pending
      // status; the app layer remains the real recipient control.
      allow create: if isSuperAdmin() || (
        isAuthenticated() &&
        request.resource.data.tenantId != null &&
        (isTenantManagerOrAdmin(request.resource.data.tenantId) ||
         isTenantFinanceAdmin(request.resource.data.tenantId)) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.purpose is string &&
        request.resource.data.purpose.size() > 0 &&
        request.resource.data.to is list &&
        request.resource.data.to.size() > 0 &&
        request.resource.data.to.size() <= 50
      );

      // Tenant admins can read email history for their tenant
      allow read: if isSuperAdmin() || (
        isAuthenticated() &&
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );

      // Only the extension (Admin SDK) updates delivery status — no client writes
      allow update, delete: if false;
    }

    // Money module collections
    match /customers/{docId} {
      // Legacy global money collections are no longer used by the app; restrict to superadmins.
      allow read, write: if isSuperAdmin();
    }

    match /invoices/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /payments_received/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /vendors/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /bills/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /bill_payments/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /expenses/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // ============================================
    // PUBLIC INVOICE LINKS (hosted invoice pages, /i/:token)
    // Doc id IS the unguessable share token; docs hold a sanitized
    // invoice + branding snapshot written by the tenant admin's client.
    // Public access is get-only (no list), so links can't be enumerated.
    // ============================================
    match /invoice_links/{token} {
      // `resource == null` (doc doesn't exist) must be allowed or the
      // admin client's create-or-update existence check is denied — the
      // caller just gets NOT_FOUND, and tokens are unguessable anyway.
      allow get: if resource == null ||
        resource.data.revoked == false ||
        isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantFinanceAdmin(resource.data.tenantId));
      allow list: if isSuperAdmin();

      allow create: if isSuperAdmin() || (
        request.resource.data.tenantId != null &&
        isTenantFinanceAdmin(request.resource.data.tenantId) &&
        request.resource.data.keys().hasAll(['tenantId', 'invoiceId', 'invoice', 'settings', 'revoked', 'viewedAt']) &&
        request.resource.data.revoked == false
      );

      // Two update paths:
      //  1. Tenant admins refresh the snapshot (payment recorded, cancel,
      //     template change) — tenant binding must not change.
      //  2. The customer's (unauthenticated) device stamps viewedAt exactly
      //     once, with the server time, touching nothing else.
      allow update: if isSuperAdmin() || (
          resource.data.tenantId != null &&
          request.resource.data.tenantId == resource.data.tenantId &&
          isTenantFinanceAdmin(resource.data.tenantId)
        ) || (
          resource.data.revoked == false &&
          resource.data.viewedAt == null &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedAt']) &&
          request.resource.data.viewedAt == request.time
        );

      // Deletes have no request.resource — never reference it here
      // (see tests/rules/legacy-collection-deletes.test.ts).
      allow delete: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantFinanceAdmin(resource.data.tenantId));
    }

    // ============================================
    // PUBLIC JOB APPLICATIONS
    // Candidates submit via /apply/:jobId (unauthenticated).
    // Create is public but heavily constrained. Read/update/delete is
    // limited to tenant staff so PII is not exposed back to the world.
    // ============================================
    match /jobApplications/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && canAccessHiringRecords(resource.data.tenantId));

      allow create: if
        request.resource.data.keys().hasAll(['tenantId', 'jobId', 'jobTitle', 'name', 'email', 'phone', 'resumePath', 'status']) &&
        request.resource.data.keys().hasOnly([
          'tenantId',
          'jobId',
          'jobTitle',
          'name',
          'email',
          'phone',
          'coverNote',
          'linkedInUrl',
          'referredBy',
          'resumePath',
          'status',
          'createdAt',
          'updatedAt',
        ]) &&
        request.resource.data.status == 'pending' &&
        exists(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)) &&
        get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.status == 'open' &&
        get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.tenantId == request.resource.data.tenantId &&
        get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.title == request.resource.data.jobTitle &&
        request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 200 &&
        request.resource.data.email is string && request.resource.data.email.size() < 200 &&
        request.resource.data.phone is string && request.resource.data.phone.size() < 80 &&
        request.resource.data.tenantId is string && request.resource.data.tenantId.size() < 200 &&
        request.resource.data.jobId is string && request.resource.data.jobId.size() < 200 &&
        request.resource.data.jobTitle is string && request.resource.data.jobTitle.size() < 400 &&
        (!request.resource.data.keys().hasAny(['coverNote']) || (request.resource.data.coverNote is string && request.resource.data.coverNote.size() < 5000)) &&
        (!request.resource.data.keys().hasAny(['linkedInUrl']) || (request.resource.data.linkedInUrl is string && request.resource.data.linkedInUrl.size() < 500)) &&
        (!request.resource.data.keys().hasAny(['referredBy']) || (request.resource.data.referredBy is string && request.resource.data.referredBy.size() < 200)) &&
        request.resource.data.resumePath is string &&
        request.resource.data.resumePath.size() < 1000 &&
        request.resource.data.resumePath.matches(
          'public/jobApplications/' + request.resource.data.tenantId + '/' +
          request.resource.data.jobId + '/' + docId + '/resume\\.(pdf|doc|docx)'
        );

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        canAccessHiringRecords(resource.data.tenantId)
      );

      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );
    }

    // ============================================
    // ONBOARDING
    // ============================================
    match /onboarding/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));

      allow create: if
        !request.resource.data.keys().hasAny(['tempPassword']) &&
        (isSuperAdmin() ||
          (request.resource.data.tenantId != null &&
            isTenantAdmin(request.resource.data.tenantId)));

      allow update: if
        !request.resource.data.keys().hasAny(['tempPassword']) &&
        (isSuperAdmin() || (
          resource.data.tenantId != null &&
          request.resource.data.tenantId == resource.data.tenantId &&
          isTenantAdmin(resource.data.tenantId)
        ));

      allow delete: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        isTenantAdmin(resource.data.tenantId)
      );
    }

    // ============================================
    // OFFBOARDING
    // ============================================
    match /offboarding/{docId} {
      allow read: if isSuperAdmin() ||
        (resource.data.tenantId != null && isTenantAdmin(resource.data.tenantId));

      allow create: if isSuperAdmin() || (
        request.resource.data.tenantId != null &&
        isTenantAdmin(request.resource.data.tenantId) &&
        request.resource.data.status == 'pending'
      );

      allow update: if isSuperAdmin() || (
        resource.data.tenantId != null &&
        request.resource.data.tenantId == resource.data.tenantId &&
        isTenantAdmin(resource.data.tenantId) &&
        resource.data.status in ['pending', 'in_progress'] &&
        (
          request.resource.data.status in ['pending', 'in_progress', 'cancelled'] ||
          (
            request.resource.data.status == 'completed' &&
            request.resource.data.checklist.accessRevoked == true &&
            request.resource.data.checklist.equipmentReturned == true &&
            request.resource.data.checklist.documentsSigned == true &&
            request.resource.data.checklist.knowledgeTransfer == true &&
            request.resource.data.checklist.finalPayCalculated == true &&
            request.resource.data.checklist.benefitsCancelled == true &&
            request.resource.data.checklist.exitInterviewCompleted == true &&
            request.resource.data.checklist.referenceLetter == true &&
            request.resource.data.checklist.inssCessationDeclared == true &&
            request.resource.data.exitInterview.completed == true &&
            request.resource.data.includeArt56Severance is bool &&
            request.resource.data.article56FinalPay.reviewAcknowledged == true &&
            request.resource.data.article56FinalPay.reviewNote is string &&
            request.resource.data.article56FinalPay.reviewNote.size() > 0 &&
            existsAfter(/databases/$(database)/documents/tenants/$(resource.data.tenantId)/employees/$(resource.data.employeeId)) &&
            getAfter(/databases/$(database)/documents/tenants/$(resource.data.tenantId)/employees/$(resource.data.employeeId)).data.status == 'terminated' &&
            getAfter(/databases/$(database)/documents/tenants/$(resource.data.tenantId)/employees/$(resource.data.employeeId)).data.terminationDate == request.resource.data.lastWorkingDay &&
            getAfter(/databases/$(database)/documents/tenants/$(resource.data.tenantId)/employees/$(resource.data.employeeId)).data.severanceOnTermination == request.resource.data.includeArt56Severance
          )
        )
      );

      // Completed/cancelled leaver records are retained as an audit trail.
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // CONNECTION TEST (used by FirebaseContext health check)
    // ============================================
    match /_connection_test/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Read-only — app only queries, never writes
    }
  }
}
